# Our API (inbound authentication)
APP_API_KEY=

# LLM Provider — "openrouter", "anthropic", or "auto" (default: auto = openrouter if key set, else anthropic)
LLM_PROVIDER=auto

# OpenRouter (primary)
OPENROUTER_API_KEY=

# Anthropic (fallback)
ANTHROPIC_API_KEY=

# Twitter/X — bearer for reading, OAuth for posting replies
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
AUTO_POST_REPLIES=false

# Optional overrides
CLAUDE_MODEL=claude-sonnet-4-20250514
MAX_REPLY_TOKENS=300

# Scheduler (daily Twitter scan)
SCAN_HOUR=17
SCAN_MINUTE=0
SCAN_TIMEZONE=America/New_York
SCAN_MAX_RESULTS=20

# Email report (Gmail: use App Password from https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
REPORT_EMAIL_TO=
